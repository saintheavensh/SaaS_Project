{
    "name": "@my-saas-app/db",
    "version": "1.0.0",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "typecheck": "tsc --build",
        "test": "vitest run --exclude dist",
        "db:generate": "drizzle-kit generate:pg",
        "db:migrate": "tsx src/migrate.ts",
        "db:push": "drizzle-kit push:pg"
    },
    "dependencies": {
        "@my-saas-app/types": "workspace:^",
        "drizzle-orm": "^0.30.0",
        "postgres": "^3.4.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "dotenv": "^16.4.0",
        "drizzle-kit": "^0.20.0",
        "typescript": "latest",
        "vitest": "^4.0.18"
    }
}